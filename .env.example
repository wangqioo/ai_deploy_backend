# 数据库（复用官方 xiaozhi-esp32-server 的 MySQL）
DATABASE_URL="mysql://root:password@localhost:3306/xiaozhi"

# Redis（复用官方 Redis）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 后端服务
PORT=8088
NODE_ENV=development

# 管理员账号（后台登录用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=xiaozhi123

# JWT 密钥
JWT_SECRET=change-this-to-a-strong-random-secret

# CORS 允许的前端地址
CORS_ORIGIN=http://localhost:5173

# EspLink 微信小程序配网集成
WX_APPID=                          # 小程序 AppID，留空则使用 dev 模式（code 直接当 openid）
WX_SECRET=                         # 小程序 AppSecret
WS_BASE_URL=ws://localhost:8088    # 返回给固件的 WebSocket 基础地址（生产改为 wss://your-domain）
REQUIRE_DEVICE_PSK=false           # 生产开启 true 前，先创建 production_keys 并写入每台设备 PSK
OTA_CHECK_RATE_LIMIT=10            # /api/ota/check 每个 IP+MAC 的窗口内允许次数
OTA_CHECK_RATE_WINDOW_SECONDS=60
DEVICE_AI_RATE_LIMIT=20            # 已绑定设备 AI 对话每个 MAC 的窗口内允许次数
DEVICE_AI_RATE_WINDOW_SECONDS=60
UNBOUND_DEVICE_AI_RATE_LIMIT=3     # 未绑定设备更严格，防止未绑定 token 消耗额度
UNBOUND_DEVICE_AI_RATE_WINDOW_SECONDS=300

# LLM 代理默认模型（租户未分配模型时使用）
DEFAULT_AI_MODEL=deepseek-chat
